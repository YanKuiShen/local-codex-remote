# Connector（本机）环境变量示例
# 文件不提交到仓库；使用时复制为本机启动脚本中的 inline env。

# 本机 connector 连接的中转站 WebSocket 地址（推荐）
RELAY_WS=wss://your-domain.example.com/agent

# 可选：只配域名/端口，不含 /agent，程序会自动补全
PUBLIC_BASE_URL=https://your-domain.example.com
RELAY_BASE_URL=https://your-domain.example.com
RELAY_BASE=your-domain.example.com
RELAY_PORT=8787

# 可选：电脑端工作区和 Codex 可执行文件
CODEX_REMOTE_WORKSPACE=/Users/you/CodexRemoteWorkspace
CODEX_BIN=/usr/local/bin/codex

# 可选：macOS 桌面强制同步。
# paste：手机消息会粘贴并发送到已打开的 Codex 桌面窗口，再轮询同一线程历史把桌面回复回传网页。
# off：不操作桌面窗口，使用后台 codex app-server 通道。
# paste 模式不会自动回退；如果权限或窗口不对，网页会直接显示错误，避免误以为已同步到桌面。
# paste 需要给运行 connector 的终端/Node 辅助功能权限，并确保 Codex 桌面窗口打开在目标对话上。
CODEX_DESKTOP_SYNC_MODE=paste
CODEX_DESKTOP_SYNC_POLL_MS=250
CODEX_DESKTOP_SYNC_TIMEOUT_MS=180000
CODEX_DESKTOP_SYNC_PASTE_DELAY_MS=350

# 可选：固定 key（16 位 hex），不设置则从 ~/.codex-remote-connector/key 读取/生成
# CONNECTOR_KEY=abcdef1234567890

# 可选：连接与保活参数
CONNECTOR_HEARTBEAT_MS=25000
CONNECTOR_PONG_TIMEOUT_MS=75000
CONNECTOR_RECONNECT_INITIAL_MS=1000
CONNECTOR_RECONNECT_MAX_MS=60000
CONNECTOR_RECONNECT_JITTER_MS=500
# 0 表示无限重试
CONNECTOR_RECONNECT_MAX_ATTEMPTS=0
