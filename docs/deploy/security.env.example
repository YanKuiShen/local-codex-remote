# Relay 安全运行示例（请按实际环境修改）
# 不要提交真实密码；文件本身应限制 600 权限

PORT=8787
HOST=127.0.0.1
PUBLIC_BASE_URL=https://your-subdomain.yourdomain.com
CONNECTOR_BUNDLE_PATH=/opt/local-codex/connector-bundle.cjs
CONNECTOR_TLS_CA_PATH=/opt/local-codex/relay-cert.pem

# 不在仓库中写明文管理员密钥
CODEX_ADMIN_KEY_FILE=/opt/local-codex/secrets/codex-admin-key.txt
# 可选：支持多个IP，示例 1.2.3.4 和 10.0.0.0/24
CODEX_IP_ALLOWLIST=1.2.3.4/32,10.0.0.0/24
# 可选：你的电脑端 16 位密钥白名单，多个用英文逗号分隔。不要提交真实值。
CODEX_AUTH_KEY_ALLOWLIST=

# 建议配合云 WAF/防火墙只放行上述白名单到 80/443；服务本体默认只监听 22/80/443 对外。

# 缩短会话有效期（默认 15 分钟，管理员 5 分钟）
CODEX_SESSION_TTL_MS=900000
CODEX_ADMIN_SESSION_TTL_MS=300000

# 安全告警（可选）
# 例1：写入安全日志
CODEX_SECURITY_AUDIT_LOG_PATH=/opt/local-codex/logs/security.log
# 例2：告警 Webhook（钉钉/飞书/企业微信都可挂飞书机器人或自建网关）
CODEX_SECURITY_ALERT_WEBHOOK=https://your-alert-endpoint.example.com/webhook/security
# 每种事件每 60 秒最多发一次告警
CODEX_SECURITY_ALERT_THROTTLE_MS=60000

# 失败次数防爆破
CODEX_AUTH_RATE_WINDOW_MS=600000
CODEX_AUTH_RATE_MAX_FAILS=5
CODEX_AUTH_RATE_BLOCK_MS=60000
CODEX_ADMIN_RATE_WINDOW_MS=600000
CODEX_ADMIN_RATE_MAX_FAILS=6
CODEX_ADMIN_RATE_BLOCK_MS=1200000

# 并发控制
CODEX_MAX_USER_SESSIONS=500
CODEX_MAX_CONNECTORS=300
CONNECTOR_CHAT_QUEUE_LIMIT=8
CONNECTOR_CHAT_QUEUE_TIMEOUT_MS=300000

# 安全建议：优先通过 CODEX_ADMIN_KEY_FILE 注入管理员密钥，不要把 CODEX_ADMIN_KEY 明文写进仓库/截图
