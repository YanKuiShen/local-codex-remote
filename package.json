{
  "name": "local-codex-remote",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/server\" \"npm run dev -w apps/mobile-web\"",
    "dev:server": "npm run dev -w apps/server",
    "dev:mobile": "npm run dev -w apps/mobile-web",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "playwright-core": "^1.61.0",
    "typescript": "^5.9.3"
  }
}
